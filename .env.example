# Server-only wallet used by server-side 0G writes such as reputation summaries.
# Mission proof uploads are paid by each user's Privy wallet.
# Never prefix this with NEXT_PUBLIC_ and never commit your real key.
ZERO_G_PRIVATE_KEY=

# 0G mainnet defaults from docs. Override only if the hackathon provides a custom endpoint.
ZERO_G_CHAIN_ID=16661
ZERO_G_RPC_URL=https://evmrpc.0g.ai
ZERO_G_INDEXER_URL=https://indexer-storage-turbo.0g.ai
ZERO_G_FLOW_CONTRACT_ADDRESS=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
ZERO_G_EXPLORER_BASE_URL=https://chainscan.0g.ai

# 0G Compute powers the Proof Agent reputation summary.
# Use a Router API key from the 0G Private Computer dashboard.
ZERO_G_COMPUTE_API_KEY=
ZERO_G_COMPUTE_BASE_URL=https://router-api.0g.ai/v1
ZERO_G_COMPUTE_MODEL=zai-org/GLM-5-FP8

# Supabase is used for production proof receipt indexes and fast UI reads.
# Use the service role key only on the server. Do not expose it as NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Privy powers wallet/email/social login in the browser.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# ProofPlay's own on-chain proof registry, deployed to 0G mainnet.
# Users anchor each 0G Storage proof root here from their Privy wallet.
NEXT_PUBLIC_PROOF_REGISTRY_ADDRESS=
